@model EduGestor.Models.Grade

@{
    ViewData["Title"] = "Delete Grade";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold text-danger mb-1">
            Delete Grade
        </h2>

        <p class="text-muted mb-0">
            Are you sure you want to delete this grade?
        </p>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4">

    <div class="card-body p-4">

        <dl class="row">

            <dt class="col-sm-3">
                Student
            </dt>

            <dd class="col-sm-9">
                @Model.Registration?.Student?.Name
            </dd>

            <dt class="col-sm-3">
                Discipline
            </dt>

            <dd class="col-sm-9">
                @Model.DisciplineClass?.Discipline?.Name
            </dd>

            <dt class="col-sm-3">
                Grade
            </dt>

            <dd class="col-sm-9">
                @Model.StudentGrade.ToString("F1")
            </dd>

            <dt class="col-sm-3">
                Frequency
            </dt>

            <dd class="col-sm-9">
                @Model.Frequency.ToString("F2")%
            </dd>

            <dt class="col-sm-3">
                Bimester
            </dt>

            <dd class="col-sm-9">
                @Model.Bimester
            </dd>

            <dt class="col-sm-3">
                School Year
            </dt>

            <dd class="col-sm-9">
                @Model.SchoolYear
            </dd>

        </dl>

        <form asp-action="Delete">

            <input type="hidden" asp-for="Id" />

            <div class="d-flex gap-2 mt-4">

                <button type="submit"
                        class="btn btn-danger">

                    <i class="bi bi-trash"></i>
                    Delete

                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">

                    Cancel

                </a>

            </div>

        </form>

    </div>

</div>

