@model IEnumerable<EduGestor.Models.Grade>

@{
    ViewData["Title"] = "Grades";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>

        <h2 class="fw-bold mb-1">
            Grades
        </h2>

        <p class="text-muted mb-0">
            Manage students grades and frequencies
        </p>

    </div>

    <a asp-action="Create"
       class="btn btn-primary shadow-sm rounded-3">

        <i class="bi bi-plus-circle"></i>
        New Grade

    </a>

</div>

<div class="card border-0 shadow-sm rounded-4">

    <div class="card-body">

        <div class="table-responsive">

            <table class="table align-middle table-hover">

                <thead class="table-light">

                    <tr>

                        <th>Student</th>
                        <th>Class</th>
                        <th>Discipline</th>
                        <th>Teacher</th>
                        <th>Grade</th>
                        <th>Frequency</th>
                        <th>Bimester</th>
                        <th>Year</th>
                        <th width="180"></th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <!-- STUDENT -->
                            <td>

                                <strong>
                                    @item.Registration?.Student?.Name
                                </strong>

                            </td>

                            <!-- CLASS -->
                            <td>

                                <span class="badge bg-primary">
                                    @item.Registration?.StudentClass?.Code                                   
                                </span>

                            </td>

                            <!-- DISCIPLINE -->
                            <td>
                                @item.DisciplineClass?.Discipline?.Name                                                             
                            </td>

                            <!-- TEACHER -->
                            <td>
                                @item.DisciplineClass?.Teacher?.Name
                            </td>

                            <!-- GRADE -->
                            <td>

                                <strong>
                                    @item.StudentGrade
                                </strong>

                            </td>

                            <!-- FREQUENCY -->
                            <td>

                                @item.Frequency%

                            </td>

                            <!-- BIMESTER -->
                            <td>

                                @item.Bimester º

                            </td>

                            <!-- YEAR -->
                            <td>

                                @item.SchoolYear

                            </td>

                            <!-- ACTIONS -->
                            <td>

                                <div class="d-flex gap-2">

                                    <a asp-action="Details"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-info text-white">

                                        <i class="bi bi-eye"></i>

                                    </a>

                                    <a asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-warning">

                                        <i class="bi bi-pencil"></i>

                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-danger">

                                        <i class="bi bi-trash"></i>

                                    </a>

                                </div>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>
