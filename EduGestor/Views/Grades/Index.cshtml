@model EduGestor.Models.ViewModels.GradeSearchViewModel
@using EduGestor.Models.Enums

@{
    ViewData["Title"] = "Grades";
}

<style>

    td, th {
        vertical-align: middle !important;
    }

    table {
        white-space: nowrap;
    }

</style>

<div class="d-flex justify-content-between align-items-center mb-4">

    <a asp-action="Create"
       class="btn btn-primary shadow-sm rounded-3">

        <i class="bi bi-plus-circle"></i>
        New Grade

    </a>

</div>

<!-- FILTERS -->
<div class="card border-0 shadow-sm rounded-4 mb-4">

    <div class="card-body">

        <form method="get"
              asp-action="Index">

            <div class="row g-3 align-items-end">

                <!-- GLOBAL SEARCH -->
                <div class="col-md-5">

                    <label class="form-label fw-semibold">
                        Search
                    </label>

                    <input asp-for="Search"
                           class="form-control"
                           placeholder="Student, class, discipline or teacher..." />

                </div>

                <!-- GRADE RANGE -->
                <div class="col-md-2">

                    <label asp-for="MinGrade"
                           class="form-label fw-semibold">

                        Min Grade

                    </label>

                    <input asp-for="MinGrade"
                           type="number"
                           step="0.01"
                           class="form-control" />

                </div>

                <div class="col-md-2">

                    <label asp-for="MaxGrade"
                           class="form-label fw-semibold">

                        Max Grade

                    </label>

                    <input asp-for="MaxGrade"
                           type="number"
                           step="0.01"
                           class="form-control" />

                </div>

                <!-- STATUS -->
                <div class="col-md-2">

                    <label asp-for="Status"
                           class="form-label fw-semibold">

                        Status

                    </label>

                    <select asp-for="Status"
                            class="form-select">

                        <option value="">
                            All
                        </option>

                        <option value="@AcademicStatus.Approved">
                            Approved
                        </option>

                        <option value="@AcademicStatus.Recovery">
                            Recovery
                        </option>

                        <option value="@AcademicStatus.FailedByGrade">
                            Failed Grade
                        </option>

                        <option value="@AcademicStatus.FailedByAttendance">
                            Failed Attendance
                        </option>

                    </select>

                </div>

                <!-- BUTTON -->
                <div class="col-md-1 d-grid">

                    <button type="submit"
                            class="btn btn-dark">

                        <i class="bi bi-search"></i>

                    </button>

                </div>

            </div>

        </form>

    </div>

</div>

<!-- TABLE -->
<div class="card border-0 shadow-sm rounded-4">

    <div class="card-body">

        <div class="table-responsive">

            <table class="table table-hover align-middle">

                <thead class="table-light">

                    <tr>

                        <th style="min-width: 220px;">
                            Student
                        </th>

                        <th style="min-width: 120px;">
                            Class
                        </th>

                        <th style="min-width: 180px;">
                            Discipline
                        </th>

                        <th style="min-width: 200px;">
                            Teacher
                        </th>

                        <th class="text-center">
                            Grade
                        </th>

                        <th class="text-center">
                            Frequency
                        </th>

                        <th class="text-center">
                            Status
                        </th>

                        <th class="text-center">
                            Bimester
                        </th>

                        <th class="text-center">
                            Year
                        </th>

                        <th width="180"></th>

                    </tr>

                </thead>

                <tbody>

                    @if (!Model.Grades!.Any())
                    {
                        <tr>

                            <td colspan="10"
                                class="text-center text-muted py-5">

                                No grades found.

                            </td>

                        </tr>
                    }

                    @foreach (var item in Model.Grades!)
                    {
                        <tr>

                            <!-- STUDENT -->
                            <td>

                                <div class="fw-semibold">
                                    @item.StudentName
                                </div>

                            </td>

                            <!-- CLASS -->
                            <td>

                                <strong>
                                    @item.ClassCode
                                </strong>

                            </td>

                            <!-- DISCIPLINE -->
                            <td>
                                @item.Discipline
                            </td>

                            <!-- TEACHER -->
                            <td>
                                @item.TeacherName
                            </td>

                            <!-- GRADE -->
                            <td class="text-center">

                                <strong class="fs-6">
                                    @item.Grade.ToString("F1")
                                </strong>

                            </td>

                            <!-- FREQUENCY -->
                            <td class="text-center">

                                @item.Frequency.ToString("F0")%

                            </td>

                            <!-- STATUS -->
                            <td class="text-center">

                                @switch (item.Status)
                                {
                                    case AcademicStatus.Approved:

                                        <span class="badge bg-success px-3 py-2">
                                            Approved
                                        </span>

                                        break;

                                    case AcademicStatus.Recovery:

                                        <span class="badge bg-warning text-dark px-3 py-2">
                                            Recovery
                                        </span>

                                        break;

                                    case AcademicStatus.FailedByAttendance:

                                        <span class="badge bg-danger px-3 py-2">
                                            Failed Attendance
                                        </span>

                                        break;

                                    case AcademicStatus.FailedByGrade:

                                        <span class="badge bg-danger px-3 py-2">
                                            Failed Grade
                                        </span>

                                        break;

                                    default:

                                        <span class="badge bg-secondary px-3 py-2">
                                            In Progress
                                        </span>

                                        break;
                                }

                            </td>

                            <!-- BIMESTER -->
                            <td class="text-center">
                                @item.Bimester º
                            </td>

                            <!-- YEAR -->
                            <td class="text-center">
                                @item.SchoolYear
                            </td>

                            <!-- ACTIONS -->
                            <td>

                                <div class="d-flex gap-2">

                                    <a asp-action="Details"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-info text-white">

                                        <i class="bi bi-eye"></i>

                                    </a>

                                    <a asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-warning">

                                        <i class="bi bi-pencil"></i>

                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-danger">

                                        <i class="bi bi-trash"></i>

                                    </a>

                                </div>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

<!-- PAGINATION -->
@if (Model.TotalPages > 1)
{
    <nav class="mt-4">

        <ul class="pagination justify-content-center">

            <!-- PREVIOUS -->
            <li class="page-item
                @(Model.PageNumber == 1 ? "disabled" : "")">

                <a class="page-link"
                   asp-action="Index"
                   asp-route-PageNumber="@(Model.PageNumber - 1)"
                   asp-route-Search="@Model.Search"
                   asp-route-MinGrade="@Model.MinGrade"
                   asp-route-MaxGrade="@Model.MaxGrade"
                   asp-route-Approved="@Model.Status">

                    Previous

                </a>

            </li>

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item
                    @(i == Model.PageNumber ? "active" : "")">

                    <a class="page-link"
                       asp-action="Index"
                       asp-route-PageNumber="@i"
                       asp-route-Search="@Model.Search"
                       asp-route-MinGrade="@Model.MinGrade"
                       asp-route-MaxGrade="@Model.MaxGrade"
                       asp-route-Approved="@Model.Status">

                        @i

                    </a>

                </li>
            }

            <!-- NEXT -->
            <li class="page-item
                @(Model.PageNumber == Model.TotalPages
                    ? "disabled" : "")">

                <a class="page-link"
                   asp-action="Index"
                   asp-route-PageNumber="@(Model.PageNumber + 1)"
                   asp-route-Search="@Model.Search"
                   asp-route-MinGrade="@Model.MinGrade"
                   asp-route-MaxGrade="@Model.MaxGrade"
                   asp-route-Approved="@Model.Status">

                    Next

                </a>

            </li>

        </ul>

    </nav>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
