@model IEnumerable<EduGestor.Models.Student>
@using EduGestor.Extensions

@{
    ViewData["Title"] = "Students";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>
        <h2 class="fw-bold mb-1">
            @ViewData["Title"]
        </h2>

        <p class="text-muted mb-0">
            Manage your @ViewData["Title"]
        </p>
    </div>

    <a asp-action="Create"
       class="btn btn-primary shadow-sm">

        <i class="bi bi-plus-circle"></i>
        New Student

    </a>

</div>

<!-- SEARCH -->
<div class="card border-0 shadow-sm rounded-4 mb-4">

    <div class="card-body">

        <form method="get"
              asp-action="Index">

            <div class="row g-2">

                <div class="col-md-10">

                    <input type="text"
                           name="searchString"
                           value="@ViewData["CurrentFilter"]"
                           class="form-control"
                           placeholder="Search by name, CPF or guardian..." />

                </div>

                <div class="col-md-2 d-grid">

                    <button type="submit"
                            class="btn btn-dark">

                        <i class="bi bi-search"></i>
                        Search

                    </button>

                </div>

            </div>

        </form>

    </div>

</div>

<div class="card border-0 shadow-sm rounded-4">

    <div class="card-body">

        <table class="table align-middle table-hover">

            <thead class="table-light">

                <tr>
                    <th>Name</th>
                    <th>Rg</th>
                    <th>Cpf</th>
                    <th>Birth Date</th>
                    <th>Guardian</th>
                    <th width="180"></th>
                </tr>

            </thead>

            <tbody>

                @if (!Model.Any())
                {
                    <tr>

                        <td colspan="6"
                            class="text-center text-muted py-4">

                            No students found.

                        </td>

                    </tr>
                }

                @foreach (var student in Model)
                {
                    <tr>

                        <td>
                            <strong>
                                @student.Name
                            </strong>
                        </td>

                        <td>
                            @student.Rg.ToRg()
                        </td>

                        <td>
                            @student.Cpf.ToCpf()
                        </td>

                        <td>
                            @student.BirthDate.ToString("dd/MM/yyyy")
                        </td>

                        <td>
                            @student.Guardian?.Name
                        </td>

                        <td>

                            <div class="d-flex gap-2">

                                <a asp-action="Details"
                                   asp-route-id="@student.Id"
                                   class="btn btn-sm btn-info text-white">

                                    <i class="bi bi-eye"></i>

                                </a>

                                <a asp-action="Edit"
                                   asp-route-id="@student.Id"
                                   class="btn btn-sm btn-warning">

                                    <i class="bi bi-pencil"></i>

                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@student.Id"
                                   class="btn btn-sm btn-danger">

                                    <i class="bi bi-trash"></i>

                                </a>

                            </div>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>
