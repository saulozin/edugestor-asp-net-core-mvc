@model EduGestor.ViewModels.StudentFormViewModel

@{
    ViewData["Title"] = "Edit";
}

<h4>Student</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit" asp-route-id="@Model.Student.Id" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Student.Id" />

            <div class="form-group">
                <label asp-for="Student.Name" class="control-label"></label>
                <input asp-for="Student.Name" class="form-control" />
                <span asp-validation-for="Student.Name" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Student.Rg" class="control-label"></label>
                <input asp-for="Student.Rg" class="form-control" />
                <span asp-validation-for="Student.Rg" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Student.Cpf" class="control-label"></label>
                <input asp-for="Student.Cpf" class="form-control" />
                <span asp-validation-for="Student.Cpf" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Student.BirthDate" class="control-label"></label>
                <input asp-for="Student.BirthDate" class="form-control" />
                <span asp-validation-for="Student.BirthDate" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">

                <label class="control-label">
                    Student Photo
                </label>

                <input type="file"
                       name="photo"
                       class="form-control" />

            </div>

            <div class="form-group mb-3">

                <label class="control-label">
                    Guardian
                </label>

                <select asp-for="SelectedGuardianId"
                        asp-items="Model.Guardians"
                        class="form-select">

                    <option value="">
                        No Guardian
                    </option>

                </select>

            </div>

            <hr />

            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" /> |
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
