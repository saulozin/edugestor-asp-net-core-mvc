@model EduGestor.Models.Student
@using EduGestor.Extensions

@{
    ViewData["Title"] = "Student Details";
}

<div>

    <div class="d-flex align-items-center mb-4">

        @if (!string.IsNullOrEmpty(Model.FotoUrl))
        {
            <img src="@Model.FotoUrl"
                 alt="Student Photo"
                 class="rounded-circle shadow"
                 style="
                    width: 120px;
                    height: 120px;
                    object-fit: cover;
                    border: 3px solid #dee2e6;" />
        }
        else
        {
            <div class="rounded-circle bg-secondary d-flex justify-content-center align-items-center shadow"
                 style="
                width: 120px;
                height: 120px;
                color: white;
                font-size: 48px;
                ">

                <i class="bi bi-person-fill"></i>

            </div>
        }

        <div class="ms-4">

            <h2 class="mb-1">
                @Model.Name
            </h2>

        </div>

    </div>

    <hr />

    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class="col-sm-10">
            @Model.Name
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Rg)
        </dt>
        <dd class="col-sm-10">
            @Model.Rg.ToRg()
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Cpf)
        </dt>
        <dd class="col-sm-10">
            @Model.Cpf.ToCpf()
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.BirthDate)
        </dt>
        <dd class="col-sm-10">
            @Model.BirthDate
        </dd>
        <dt class="col-sm-2">
            Guardian
        </dt>
        <dd class="col-sm-10">

            <hr />

            @if (Model.Guardian != null)
            {
                <table class="table table-hover">
                    <thead>
                        <tr class="table-light">
                            <th>@Html.DisplayNameFor(model => model.Guardian.Name)</th>
                            <th>@Html.DisplayNameFor(model => model.Guardian.Cpf)</th>
                            <th>@Html.DisplayNameFor(model => model.Guardian.Email)</th>
                            <th>@Html.DisplayNameFor(model => model.Guardian.Phone)</th>
                            <th>@Html.DisplayNameFor(model => model.Guardian.Address)</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>@Model.Guardian.Name</td>
                            <td>@Model.Guardian.Cpf.ToCpf()</td>
                            <td>@Model.Guardian.Email</td>
                            <td>@Model.Guardian.Phone.ToPhone()</td>
                            <td>@Model.Guardian.Address</td>
                        </tr>
                    </tbody>
                </table>

            }
            else
            {
                <p>No guardian registered.</p>
            }

        </dd>
    </dl>

    <h4 class="mt-4">Registrations</h4>

    @if (Model.Registrations != null && Model.Registrations.Any())
    {
        <table class="table table-striped table-hover">

            <thead>
                <tr>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Class</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var registration in Model.Registrations)
                {
                    <tr>
                        <td>
                            @registration.Date
                        </td>

                        <td>
                            @registration.Status
                        </td>

                        <td>
                            @registration.StudentClass?.Code
                        </td>
                    </tr>
                }

            </tbody>

        </table>
    }
    else
    {
        <p class="text-muted">
            No registrations found.
        </p>
    }

</div>
<hr />
<div>
    <a asp-action="Edit" class="btn btn-warning" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index" class="btn btn-secondary" >Back to List</a>
</div>
