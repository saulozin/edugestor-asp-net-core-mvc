@model EduGestor.Models.Guardian

@{
    ViewData["Title"] = "Create Guardian";
}

<h2>Create Guardian</h2>

<hr />

<div class="row">

    <div class="col-md-6">

        <form asp-action="Create">

            <input type="hidden"
                   name="studentId"
                   value="@ViewBag.StudentId" />

            <div asp-validation-summary="ModelOnly"
                 class="text-danger">
            </div>

            <div class="form-group mb-3">

                <label asp-for="Name"
                       class="control-label">
                </label>

                <input asp-for="Name"
                       class="form-control" />

                <span asp-validation-for="Name"
                      class="text-danger">
                </span>

            </div>

            <div class="form-group mb-3">

                <label asp-for="Cpf"
                       class="control-label">
                </label>

                <input asp-for="Cpf"
                       class="form-control" />

                <span asp-validation-for="Cpf"
                      class="text-danger">
                </span>

            </div>

            <div class="form-group mb-3">

                <label asp-for="Email"
                       class="control-label">
                </label>

                <input asp-for="Email"
                       class="form-control" />

                <span asp-validation-for="Email"
                      class="text-danger">
                </span>

            </div>

            <div class="form-group mb-3">

                <label asp-for="Phone"
                       class="control-label">
                </label>

                <input asp-for="Phone"
                       class="form-control" />

                <span asp-validation-for="Phone"
                      class="text-danger">
                </span>

            </div>

            <div class="form-group mb-3">

                <label asp-for="Address"
                       class="control-label">
                </label>

                <input asp-for="Address"
                       class="form-control" />

                <span asp-validation-for="Address"
                      class="text-danger">
                </span>

            </div>

            <div class="form-group">

                <input type="submit"
                       value="Create"
                       class="btn btn-primary" />

                <a asp-action="Index"
                   class="btn btn-secondary">

                    Cancel
                </a>

            </div>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
