@model IEnumerable<EduGestor.Models.Guardian>
@using EduGestor.Extensions

@{
    ViewData["Title"] = "Guardians";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>
        <h2 class="fw-bold mb-1">
            Guardians
        </h2>

        <p class="text-muted mb-0">
            Manage guardians and student associations
        </p>
    </div>

    <a asp-action="Create"
       class="btn btn-primary shadow-sm">

        <i class="bi bi-plus-circle"></i>
        New Guardian

    </a>

</div>

<div class="card border-0 shadow-sm rounded-4">

    <div class="card-body">

        <table class="table align-middle table-hover">

            <thead class="table-light">

                <tr>
                    <th>Name</th>
                    <th>CPF</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Students</th>
                    <th width="180"></th>
                </tr>

            </thead>

            <tbody>

                @foreach (var guardian in Model)
                {
                    <tr>

                        <td>
                            <strong>
                                @guardian.Name
                            </strong>
                        </td>

                        <td>
                            <strong>
                                @guardian.Cpf.ToCpf()
                            </strong>
                        </td>

                        <td>
                            @guardian.Email
                        </td>

                        <td>
                            @guardian.Phone.ToPhone()
                        </td>

                        <td>

                            <span class="badge bg-primary">
                                @guardian.Students.Count
                            </span>

                        </td>

                        <td>

                            <div class="d-flex gap-2">

                                <a asp-action="Details"
                                   asp-route-id="@guardian.Id"
                                   class="btn btn-sm btn-info text-white">

                                    <i class="bi bi-eye"></i>

                                </a>

                                <a asp-action="Edit"
                                   asp-route-id="@guardian.Id"
                                   class="btn btn-sm btn-warning">

                                    <i class="bi bi-pencil"></i>

                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@guardian.Id"
                                   class="btn btn-sm btn-danger">

                                    <i class="bi bi-trash"></i>

                                </a>

                            </div>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>
