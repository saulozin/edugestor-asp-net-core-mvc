@model EduGestor.Models.ViewModels.TeacherPortalViewModel

@{
    ViewData["Title"] = "Teacher Portal";
}

<div class="container-fluid">

    <div class="mb-4">

        <h2 class="fw-bold">
            Welcome, @Model.TeacherName
        </h2>

        <p class="text-muted">
            Academic management and class diary
        </p>

    </div>

    <div class="row g-4">

        @foreach (var item in Model.Classes)
        {
            <div class="col-lg-6">

                <div class="card border-0 shadow-sm rounded-4 h-100">

                    <div class="card-body p-4">

                        <!-- HEADER -->
                        <div class="d-flex justify-content-between align-items-start mb-4">

                            <div>

                                <h4 class="fw-bold mb-1">
                                    @item.Discipline
                                </h4>

                                <p class="text-muted mb-0">
                                    Class: @item.ClassCode
                                </p>

                            </div>

                            <div class="bg-primary bg-opacity-10
                                p-3 rounded-4">

                                <i class="bi bi-journal-bookmark-fill
                                    text-primary"
                                   style="font-size: 28px;">
                                </i>

                            </div>

                        </div>

                        <!-- STATS -->
                        <div class="row g-3 mb-4">

                            <div class="col-4">

                                <div class="bg-light rounded-4 p-3 text-center">

                                    <small class="text-muted d-block">
                                        Students
                                    </small>

                                    <h5 class="fw-bold mb-0">
                                        @item.StudentsCount
                                    </h5>

                                </div>

                            </div>

                            <div class="col-4">

                                <div class="bg-light rounded-4 p-3 text-center">

                                    <small class="text-muted d-block">
                                        Average
                                    </small>

                                    <h5 class="fw-bold mb-0 text-primary">

                                        @item.AverageGrade.ToString("F1")

                                    </h5>

                                </div>

                            </div>

                            <div class="col-4">

                                <div class="bg-light rounded-4 p-3 text-center">

                                    <small class="text-muted d-block">
                                        Frequency
                                    </small>

                                    <h5 class="fw-bold mb-0 text-success">

                                        @item.AverageFrequency.ToString("F0")%

                                    </h5>

                                </div>

                            </div>

                        </div>

                        <!-- ACTIONS -->
                        <div class="d-grid gap-2">

                            <!-- LAUNCH GRADES -->
                            <a asp-controller="Grades"
                               asp-action="Create"
                               class="btn btn-primary rounded-3">

                                <i class="bi bi-pencil-square"></i>
                                Launch Grades

                            </a>

                            <!-- LAUNCH ATTENDANCE -->
                            <a href="#"
                               class="btn btn-success rounded-3">

                                <i class="bi bi-calendar-check"></i>
                                Launch Attendance

                            </a>

                            <!-- VIEW CLASS -->
                            <a href="#"
                               class="btn btn-outline-dark rounded-3">

                                <i class="bi bi-people"></i>
                                View Class

                            </a>

                        </div>

                    </div>

                </div>

            </div>
        }


    </div>

</div>
