@model EduGestor.Models.ViewModels.GradeLaunchViewModel

@{
    ViewData["Title"] = "Launch Grades";
}

<div class="container-fluid">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2 class="fw-bold mb-1">
                Launch Grades
            </h2>

            <p class="text-muted mb-0">

                @Model.Discipline
                -
                Class @Model.ClassCode

            </p>

        </div>

        <div class="badge bg-primary fs-6 p-3">

            Bimester @Model.Bimester

        </div>

    </div>

    <!-- FORM -->
    <form asp-action="LaunchGrades"
          method="post">

        <input type="hidden"
               asp-for="DisciplineClassId" />

        <input type="hidden"
               asp-for="Discipline" />

        <input type="hidden"
               asp-for="ClassCode" />

        <input type="hidden"
               asp-for="Bimester" />

        <!-- TABLE -->
        <div class="card border-0 shadow-sm rounded-4">

            <div class="card-body">

                <div class="table-responsive">

                    <table class="table align-middle table-hover">

                        <thead class="table-light">

                            <tr>

                                <th>
                                    Student
                                </th>

                                <th width="180">
                                    Grade
                                </th>

                            </tr>

                        </thead>

                        <tbody>

                            @for (int i = 0;
                                i < Model.Students.Count;
                                i++)
                            {
                                <tr>

                                    <!-- HIDDEN IDS -->

                                    <input type="hidden"
                                           asp-for="Students[i].RegistrationId" />

                                    <input type="hidden"
                                           asp-for="Students[i].StudentName" />

                                    <!-- STUDENT -->

                                    <td>

                                        <strong>
                                            @Model.Students.ElementAt(i).StudentName
                                        </strong>

                                    </td>

                                    <!-- GRADE -->

                                    <td>

                                        <input asp-for="Students[i].Grade"
                                               class="form-control"
                                               type="number"
                                               min="0"
                                               max="10"
                                               step="0.1" />

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

        <!-- ACTIONS -->
        <div class="mt-4 d-flex gap-2">

            <button type="submit"
                    class="btn btn-success btn-lg rounded-3">

                <i class="bi bi-check-circle"></i>
                Save Grades

            </button>

            <a asp-action="Details"
               asp-route-disciplineClassId="@Model.DisciplineClassId"
               class="btn btn-outline-secondary btn-lg rounded-3">

                Back

            </a>

        </div>

    </form>

</div>
