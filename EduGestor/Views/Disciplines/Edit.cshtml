@model EduGestor.Models.Discipline

@{
    ViewData["Title"] = "Edit Discipline";
}

<h2 class="fw-bold mb-4">
    @ViewData["Title"]
</h2>

<div class="card border-0 shadow-sm rounded-4">

    <div class="card-body">

        <form asp-action="Edit">

            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly"
                 class="text-danger">
            </div>

            <div class="row">

                <div class="col-md-6 mb-3">

                    <label asp-for="Name"
                           class="form-label">
                    </label>

                    <input asp-for="Name"
                           class="form-control" />

                    <span asp-validation-for="Name"
                          class="text-danger">
                    </span>

                </div>

                <div class="col-md-6 mb-3">

                    <label asp-for="Workload"
                           class="form-label">
                    </label>

                    <input asp-for="Workload"
                           class="form-control" />

                    <span asp-validation-for="Workload"
                          class="text-danger">
                    </span>

                </div>

            </div>

            <div class="d-flex gap-2">

                <button type="submit"
                        class="btn btn-primary">

                    Save

                </button>
                |
                <a asp-action="Index"
                   class="btn btn-secondary">

                    Cancel

                </a>

            </div>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

