@model EduGestor.Models.Discipline
@using EduGestor.Extensions

@{
    ViewData["Title"] = "Delete Discipline";
}

<div class="alert alert-warning">
    <strong>Warning!</strong>
    This action cannot be undone.
</div>

<h2 class="fw-bold text-danger mb-4">
    @ViewData["Title"]
</h2>

<div class="alert alert-danger shadow-sm">

    <h5>
        Are you sure you want to delete this discipline?
    </h5>

</div>

<div class="card border-0 shadow-sm rounded-4">

    <div class="card-body">

        <dl class="row">

            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">Workload</dt>
            <dd class="col-sm-9">@Model.Workload</dd>

        </dl>

        <form asp-action="Delete">

            <input type="hidden"
                   asp-for="Id" />

            <div class="d-flex gap-2">

                <button type="submit"
                        class="btn btn-danger">

                    Delete

                </button> |

                <a asp-action="Index"
                   class="btn btn-secondary">

                    Cancel

                </a>

            </div>

        </form>

    </div>

</div>
