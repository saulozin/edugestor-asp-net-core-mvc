@model EduGestor.Models.Discipline

@{
    ViewData["Title"] = "Create Discipline";
}

<h2>@ViewData["Title"]</h2>

<hr />

<div class="row">

    <div class="col-md-6">

        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly"
                 class="text-danger">
            </div>

            <div class="form-group mb-3">

                <label asp-for="Name"
                       class="control-label">
                </label>

                <input asp-for="Name"
                       class="form-control" />

                <span asp-validation-for="Name"
                      class="text-danger">
                </span>

            </div>
            <div class="form-group mb-3">

                <label asp-for="Workload"
                       class="control-label">
                </label>

                <input asp-for="Workload"
                       class="form-control" />

                <span asp-validation-for="Workload"
                      class="text-danger">
                </span>

            </div>

            <div class="form-group">

                <input type="submit"
                       value="Create"
                       class="btn btn-primary" /> |

                <a asp-action="Index"
                   class="btn btn-secondary">

                    Cancel
                </a>

            </div>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
