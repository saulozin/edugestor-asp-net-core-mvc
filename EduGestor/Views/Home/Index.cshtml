@model EduGestor.ViewModels.DashboardViewModel
@using EduGestor.Models.Enums

@{
    ViewData["Title"] = "Dashboard";
}

<!-- HERO -->
<div class="container-fluid">

    <div class="row mb-4">

        <div class="col-12">

            <div class="p-4 rounded-4 shadow-sm text-white"
                 style="background: linear-gradient(135deg, #2563eb, #1e40af);" >

                <div class="d-flex justify-content-between align-items-center">

                    <div>

                        <h1 class="fw-bold mb-2">
                            Welcome to EduGestor
                        </h1>

                        <p class="mb-0 opacity-75">
                            School management dashboard and academic control system.
                        </p>

                    </div>

                    <div class="d-none d-md-block">

                        <i class="bi bi-mortarboard-fill"
                           style="font-size: 90px; opacity: 0.2;"></i>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <!-- STATS -->
    <div class="row g-4 mb-4">

        <!-- STUDENTS -->
        <div class="col-md-6 col-xl-3">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <p class="text-muted mb-1">
                                Students
                            </p>

                            <h2 class="fw-bold mb-0">
                                @Model.TotalStudents
                            </h2>

                        </div>

                        <div class="bg-primary bg-opacity-10 p-3 rounded-4">

                            <i class="bi bi-person-fill text-primary"
                               style="font-size: 32px;"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- GUARDIANS -->
        <div class="col-md-6 col-xl-3">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <p class="text-muted mb-1">
                                Guardians
                            </p>

                            <h2 class="fw-bold mb-0">
                                @Model.TotalGuardians
                            </h2>

                        </div>

                        <div class="bg-success bg-opacity-10 p-3 rounded-4">

                            <i class="bi bi-people-fill text-success"
                               style="font-size: 32px;"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- TEACHERS -->
        <div class="col-md-6 col-xl-3">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <p class="text-muted mb-1">
                                Teachers
                            </p>

                            <h2 class="fw-bold mb-0">
                                @Model.TotalTeachers
                            </h2>

                        </div>

                        <div class="bg-warning bg-opacity-10 p-3 rounded-4">

                            <i class="bi bi-person-badge-fill text-warning"
                               style="font-size: 32px;"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- REGISTRATIONS -->
        <div class="col-md-6 col-xl-3">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <p class="text-muted mb-1">
                                Registrations
                            </p>

                            <h2 class="fw-bold mb-0">
                                @Model.TotalRegistrations
                            </h2>

                        </div>

                        <div class="bg-danger bg-opacity-10 p-3 rounded-4">

                            <i class="bi bi-journal-check text-danger"
                               style="font-size: 32px;"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <!-- ANALYTICS -->
    <div class="row g-4 mb-4">

        <!-- SCHOOL AVERAGE -->
        <div class="col-md-4">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-body">

                    <p class="text-muted mb-1">
                        School Average
                    </p>

                    <h2 class="fw-bold text-primary">

                        @Model.SchoolAverage.ToString("F1")

                    </h2>

                </div>

            </div>

        </div>

        <!-- FREQUENCY -->
        <div class="col-md-4">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-body">

                    <p class="text-muted mb-1">
                        Average Frequency
                    </p>

                    <h2 class="fw-bold text-success">

                        @Model.AverageFrequency.ToString("F0")%

                    </h2>

                </div>

            </div>

        </div>

        <!-- APPROVAL -->
        <div class="col-md-4">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-body">

                    <p class="text-muted mb-3">
                        Academic Status
                    </p>

                    <div class="d-flex gap-3">

                        <span class="badge bg-success fs-6">

                            Approved:
                            @Model.ApprovedStudents

                        </span>

                        <span class="badge bg-danger fs-6">

                            Failed:
                            @Model.FailedStudents

                        </span>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <!-- SECOND ROW -->
    <div class="row g-4">

        <!-- RECENT STUDENTS -->
        <div class="col-lg-8">

            <div class="card border-0 shadow-sm rounded-4">

                <div class="card-header bg-white border-0 pt-4 px-4">

                    <div class="d-flex justify-content-between align-items-center">

                        <h5 class="fw-bold mb-0">
                            Recent Students Registrations
                        </h5>

                        <a asp-controller="Registrations"
                           asp-action="Index"
                           class="btn btn-sm btn-primary rounded-pill">

                            View All

                        </a>

                    </div>

                </div>

                <div class="card-body px-4 pb-4">

                    <table class="table align-middle">

                        <thead>

                            <tr>
                                <th>Name</th>
                                <th>Guardian</th>
                                <th>Status</th>
                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var obj in Model.RecentRegistrations)
                            {
                                <tr>

                                    <td>
                                        <strong>
                                            @obj.Student?.Name
                                        </strong>
                                    </td>

                                    <td>
                                        @(obj.Student?.Guardian?.Name ?? "No Guardian")
                                    </td>

                                    <td>

                                        @{
                                            var badgeClass = obj.Status switch
                                            {
                                                RegistrationStatus.Active => "bg-success",
                                                RegistrationStatus.Pending => "bg-warning",
                                                RegistrationStatus.Rejected => "bg-danger",
                                                _ => "bg-secondary"
                                            };
                                        }

                                        <span class="badge @badgeClass">
                                            @obj.Status
                                        </span>

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

        <!-- QUICK ACTIONS -->
        <div class="col-lg-4">

            <div class="card border-0 shadow-sm rounded-4 mb-4">

                <div class="card-body">

                    <h5 class="fw-bold mb-4">
                        Quick Actions
                    </h5>

                    <div class="d-grid gap-3">

                        <a asp-controller="Students"
                           asp-action="Create"
                           class="btn btn-primary btn-lg rounded-3">

                            <i class="bi bi-person-plus-fill"></i>
                            Add Student

                        </a>

                        <a asp-controller="Guardians"
                           asp-action="Create"
                           class="btn btn-success btn-lg rounded-3">

                            <i class="bi bi-people-fill"></i>
                            Add Guardian

                        </a>

                        <a asp-controller="Teachers"
                           asp-action="Create"
                           class="btn btn-warning btn-lg rounded-3">

                            <i class="bi bi-person-badge-fill"></i>
                            Add Teacher

                        </a>

                        <a asp-controller="DisciplineClasses"
                           asp-action="Index"
                           class="btn btn-dark btn-lg rounded-3">

                            <i class="bi bi-diagram-3-fill"></i>
                            Academic Assignments

                        </a>

                    </div>

                </div>

            </div>

            <!-- SYSTEM STATUS -->
            <div class="card border-0 shadow-sm rounded-4">

                <div class="card-body">

                    <h5 class="fw-bold mb-4">
                        System Status
                    </h5>

                    <div class="mb-3">

                        <div class="d-flex justify-content-between">

                            <span>
                                Academic Year
                            </span>

                            <strong>
                                @Model.SchoolYear
                            </strong>

                        </div>

                    </div>

                    <div class="mb-3">

                        <div class="d-flex justify-content-between">

                            <span>
                                Active Classes
                            </span>

                            <strong>
                                @Model.TotalStudentClasses
                            </strong>

                        </div>

                    </div>

                    <div>

                        <div class="d-flex justify-content-between">

                            <span>
                                System Status
                            </span>

                            <span class="badge bg-success">
                                Online
                            </span>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <!-- CHARTS -->
    <div class="container-fluid mt-4">

        <div class="row g-4">

            <!-- APPROVAL CHART -->
            <div class="col-xl-4">

                <div class="card border-0 shadow-sm rounded-4 h-100">

                    <div class="card-body">

                        <h5 class="fw-bold mb-4">
                            Approval Statistics
                        </h5>

                        <div style="height: 320px;">

                            <canvas id="approvalChart"></canvas>

                        </div>

                    </div>

                </div>

            </div>

            <!-- PERFORMANCE -->
            <div class="col-xl-8">

                <div class="card border-0 shadow-sm rounded-4 h-100">

                    <div class="card-body">

                        <h5 class="fw-bold mb-4">
                            School Performance
                        </h5>

                        <div style="height: 320px;">

                            <canvas id="performanceChart"></canvas>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

@section Scripts {

    <script>

        // =========================
        // APPROVAL CHART
        // =========================

        new Chart(
        document.getElementById('approvalChart'),
        {
        type: 'doughnut',

        data:
        {
        labels:
        [
        'Approved',
        'Failed'
        ],

        datasets:
        [
        {
        data:
        [
        @Model.ApprovedStudents,
        @Model.FailedStudents
        ]
        }
        ]
        },

        options:
        {
        responsive: true
        }
        });

        // =========================
        // PERFORMANCE CHART
        // =========================

        new Chart(
            document.getElementById('performanceChart'),
            {
                type: 'bar',

                data:
                {
                    labels:
                    [
                        'School Average',
                        'Frequency'
                    ],

                    datasets:
                    [
                        {
                            label: 'Metrics',

                            data:
                            [
                                @Model.SchoolAverage,
                                @Model.AverageFrequency
                            ]
                        }
                    ]
                },

                options:
                {
                    responsive: true,

                    scales:
                    {
                        y:
                        {
                            beginAtZero: true,
                            max: 100
                        }
                    }
                }
            });

    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
