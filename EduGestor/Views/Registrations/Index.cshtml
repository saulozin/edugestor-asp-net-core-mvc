@model EduGestor.Models.ViewModels.RegistrationSearchViewModel
@using EduGestor.Models.Enums

@{
    ViewData["Title"] = "Registrations";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <a asp-action="Create"
       class="btn btn-primary shadow-sm">

        <i class="bi bi-plus-circle"></i>
        New Registration

    </a>

</div>

<!-- FILTERS -->
<div class="card border-0 shadow-sm rounded-4 mb-4">

    <div class="card-body">

        <form method="get"
              asp-action="Index">

            <div class="row g-3">

                <!-- STUDENT -->
                <div class="col-md-4">

                    <label asp-for="StudentName"
                           class="form-label fw-semibold">

                        Student

                    </label>

                    <input asp-for="StudentName"
                           class="form-control"
                           placeholder="Search student..." />

                </div>

                <!-- STATUS -->
                <div class="col-md-2">

                    <label asp-for="Status"
                           class="form-label fw-semibold">

                        Status

                    </label>

                    <select asp-for="Status"
                            class="form-select">

                        <option value="">
                            All
                        </option>

                        @foreach (var status in Enum.GetValues(typeof(EduGestor.Models.Enums.RegistrationStatus)))
                        {
                            <option value="@status">
                                @status
                            </option>
                        }

                    </select>

                </div>

                <!-- START DATE -->
                <div class="col-md-2">

                    <label asp-for="StartDate"
                           class="form-label fw-semibold">

                        Start Date

                    </label>

                    <input asp-for="StartDate"
                           type="date"
                           class="form-control" />

                </div>

                <!-- END DATE -->
                <div class="col-md-2">

                    <label asp-for="EndDate"
                           class="form-label fw-semibold">

                        End Date

                    </label>

                    <input asp-for="EndDate"
                           type="date"
                           class="form-control" />

                </div>

                <!-- BUTTON -->
                <div class="col-md-2 d-grid align-items-end">

                    <button type="submit"
                            class="btn btn-dark">

                        <i class="bi bi-search"></i>
                        Search

                    </button>

                </div>

            </div>

        </form>

    </div>

</div>

<!-- TABLE -->
<div class="card border-0 shadow-sm rounded-4">

    <div class="card-body">

        <table class="table align-middle table-hover">

            <thead class="table-light">

                <tr>

                    <th>
                        Registration Date
                    </th>

                    <th>
                        Status
                    </th>

                    <th>
                        Student
                    </th>

                    <th>
                        Student Class
                    </th>

                    <th width="180"></th>

                </tr>

            </thead>

            <tbody>

                @if (!Model.Registrations!.Any())
                {
                    <tr>

                        <td colspan="5"
                            class="text-center text-muted py-4">

                            No registrations found.

                        </td>

                    </tr>
                }

                @foreach (var reg in Model.Registrations!)
                {
                    <tr>

                        <!-- DATE -->
                        <td>

                            <strong>
                                @reg.Date
                            </strong>

                        </td>

                        <!-- STATUS -->
                        <td>

                            @{
                                var badgeClass = reg.Status switch
                                {
                                    RegistrationStatus.Active => "bg-success",
                                    RegistrationStatus.Pending => "bg-warning",
                                    RegistrationStatus.Rejected => "bg-danger",
                                    _ => "bg-secondary"
                                };
                            }

                            <span class="badge @badgeClass">

                                @reg.Status

                            </span>

                        </td>

                        <!-- STUDENT -->
                        <td>

                            @reg.Student?.Name

                        </td>

                        <!-- CLASS -->
                        <td>

                            @reg.StudentClass?.Code

                        </td>

                        <!-- ACTIONS -->
                        <td>

                            <div class="d-flex gap-2">

                                <a asp-action="Details"
                                   asp-route-id="@reg.Id"
                                   class="btn btn-sm btn-info text-white">

                                    <i class="bi bi-eye"></i>

                                </a>

                                <a asp-action="Edit"
                                   asp-route-id="@reg.Id"
                                   class="btn btn-sm btn-warning">

                                    <i class="bi bi-pencil"></i>

                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@reg.Id"
                                   class="btn btn-sm btn-danger">

                                    <i class="bi bi-trash"></i>

                                </a>

                            </div>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

<!-- PAGINATION -->
@if (Model.TotalPages > 1)
{
    <nav class="mt-4">

        <ul class="pagination justify-content-center">

            <!-- PREVIOUS -->
            <li class="page-item
                @(Model.PageNumber == 1 ? "disabled" : "")">

                <a class="page-link"
                   asp-action="Index"
                   asp-route-PageNumber="@(Model.PageNumber - 1)"

                   asp-route-StudentName="@Model.StudentName"
                   asp-route-Status="@Model.Status"
                   asp-route-StartDate="@Model.StartDate?.ToString("yyyy-MM-dd")"
                   asp-route-EndDate="@Model.EndDate?.ToString("yyyy-MM-dd")"
                   asp-route-StudentClassId="@Model.StudentClassId">

                    Previous

                </a>

            </li>

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item
                    @(i == Model.PageNumber ? "active" : "")">

                    <a class="page-link"
                       asp-action="Index"
                       asp-route-PageNumber="@i"

                       asp-route-StudentName="@Model.StudentName"
                       asp-route-Status="@Model.Status"
                       asp-route-StartDate="@Model.StartDate?.ToString("yyyy-MM-dd")"
                       asp-route-EndDate="@Model.EndDate?.ToString("yyyy-MM-dd")"
                       asp-route-StudentClassId="@Model.StudentClassId">

                        @i

                    </a>

                </li>
            }

            <!-- NEXT -->
            <li class="page-item
                @(Model.PageNumber == Model.TotalPages
                    ? "disabled" : "")">

                <a class="page-link"
                   asp-action="Index"
                   asp-route-PageNumber="@(Model.PageNumber + 1)"

                   asp-route-StudentName="@Model.StudentName"
                   asp-route-Status="@Model.Status"
                   asp-route-StartDate="@Model.StartDate?.ToString("yyyy-MM-dd")"
                   asp-route-EndDate="@Model.EndDate?.ToString("yyyy-MM-dd")"
                   asp-route-StudentClassId="@Model.StudentClassId">

                    Next

                </a>

            </li>

        </ul>

    </nav>
}
