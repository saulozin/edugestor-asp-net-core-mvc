@model IEnumerable<EduGestor.Models.Registration>

@{
    ViewData["Title"] = "Registrations";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>
        <h2 class="fw-bold mb-1">
            @ViewData["Title"]
        </h2>

        <p class="text-muted mb-0">
            Manage Registrations and your students and classes rooms associations
        </p>
    </div>

    <a asp-action="Create"
       class="btn btn-primary shadow-sm">

        <i class="bi bi-plus-circle"></i>
        New Registration

    </a>

</div>

<div class="card border-0 shadow-sm rounded-4">

    <div class="card-body">

        <table class="table align-middle table-hover">

            <thead class="table-light">

                <tr>
                    <th>Registration Date</th>
                    <th>Status</th>
                    <th>Student</th>
                    <th>Student Class</th>
                    <th width="180"></th>
                </tr>

            </thead>

            <tbody>

                @foreach (var reg in Model)
                {
                    <tr>

                        <td>
                            <strong>
                                @reg.Date
                            </strong>
                        </td>

                        <td>
                            <strong>
                                @reg.Status
                            </strong>
                        </td>

                        <td>
                            @reg.Student?.Name
                        </td>

                        <td>
                            @reg.StudentClass?.Code
                        </td>

                        <td>

                            <div class="d-flex gap-2">

                                <a asp-action="Details"
                                   asp-route-id="@reg.Id"
                                   class="btn btn-sm btn-info text-white">

                                    <i class="bi bi-eye"></i>

                                </a>

                                <a asp-action="Edit"
                                   asp-route-id="@reg.Id"
                                   class="btn btn-sm btn-warning">

                                    <i class="bi bi-pencil"></i>

                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@reg.Id"
                                   class="btn btn-sm btn-danger">

                                    <i class="bi bi-trash"></i>

                                </a>

                            </div>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>
