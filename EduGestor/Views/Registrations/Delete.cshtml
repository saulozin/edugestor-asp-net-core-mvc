@model EduGestor.Models.Registration

@{
    ViewData["Title"] = "Delete Registration";
}

<h2 class="fw-bold text-danger mb-4">
    @ViewData["Title"]
</h2>

<div class="alert alert-danger shadow-sm">

    <h5>
        Are you sure you want to delete this registration?
    </h5>

</div>

<div class="card border-0 shadow-sm rounded-4">

    <div class="card-body">

        <div class="d-flex align-items-center mb-4">
            <div class="ms-4">
                <h2 class="mb-1">
                    Student: @Model.Student?.Name
                </h2>
            </div>
        </div>
        <hr />
        <dl class="row">
            <dt class="col-sm-2">
                Registration Date
            </dt>
            <dd class="col-sm-10">
                @Model.Date
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Status)
            </dt>
            <dd class="col-sm-10">
                @Model.Status
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.StudentId)
            </dt>
            <dd class="col-sm-10">
                @Model.Student?.Name
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.StudentClassId)
            </dt>
            <dd class="col-sm-10">
                @Model.StudentClass?.Code
            </dd>
        </dl>

        <form asp-action="Delete">

            <input type="hidden"
                   asp-for="Id" />

            <div class="d-flex gap-2">

                <button type="submit"
                        class="btn btn-danger">

                    Delete

                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">

                    Cancel

                </a>

            </div>

        </form>

    </div>

</div>
