@model EduGestor.Models.Registration
@using EduGestor.Models.Enums

@{
    ViewData["Title"] = "Registration Details";
}

<div>
    <dl class="row">

        <dt class="col-sm-2">
            Registration Date:
        </dt>
        <dd class="col-sm-10">
            @Model.Date
        </dd>

        <dt class="col-sm-2">
            Student Status:
        </dt>

        @{
            var badgeClass = Model.Status switch
            {
                RegistrationStatus.Active => "bg-success",
                RegistrationStatus.Pending => "bg-warning",
                RegistrationStatus.Rejected => "bg-danger",
                _ => "bg-secondary"
            };
        }

        <dd class="col-sm-10">
            <span class="badge @badgeClass">
                @Model.Status
            </span>
        </dd>

    </dl>
</div>

<hr />

<h3 class="fw-bold mb-4">
    Academic Report
</h3>

<div class="card shadow-sm border-0 rounded-4">

    <div class="card-body">

        <h5>
            Student:
            <strong>
                @Model.Student?.Name
            </strong>
        </h5>

        <h6 class="text-muted">
            Class:
            @Model.StudentClass?.Code
        </h6>

        <hr />

        <table class="table table-hover align-middle">

            <thead class="table-light">
                <tr>
                    <th>Discipline</th>
                    <th>Teacher</th>
                    <th>1st</th>
                    <th>2nd</th>
                    <th>3rd</th>
                    <th>4th</th>
                    <th>Average</th>
                    <th>Attendance</th>
                    <th>Status</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var discipline in Model.Grades
                    .Select(g => g.DisciplineClass)
                    .Distinct())
                {
                    <tr>

                        <!-- DISCIPLINE -->
                        <td>
                            @discipline?.Discipline?.Name
                        </td>

                        <!-- TEACHER -->
                        <td>
                            @discipline?.Teacher?.Name
                        </td>

                        <!-- BIMESTERS -->
                        @for (int bimester = 1; bimester <= 4; bimester++)
                        {
                            var grade = Model.Grades
                                .FirstOrDefault(g =>
                                    g.DisciplineClassId == discipline!.Id
                                    && g.Bimester == bimester);

                            <td>
                                @(grade?.StudentGrade.ToString("F1") ?? "-")
                            </td>
                        }

                        <!-- AVERAGE -->
                        <td>

                            <strong>
                                @(Model
                                .GetDisciplineAverage(discipline!.Id)
                                .ToString("F1"))
                            </strong>

                        </td>

                        <!-- ATTENDANCE -->
                        <td>

                            @(Model
                            .GetAttendance(discipline!.Id)
                            .ToString("F0"))%

                        </td>

                        <!-- STATUS -->
                        <td>

                            @if (Model.IsApproved(discipline!.Id))
                            {
                                <span class="badge bg-success">
                                    Approved
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    Failed
                                </span>
                            }

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

<hr />
<div>
    <a asp-action="Edit" class="btn btn-warning" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index" class="btn btn-secondary" >Back to List</a>
</div>
