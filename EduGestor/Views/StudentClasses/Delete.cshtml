@model EduGestor.Models.StudentClass

@{
    ViewData["Title"] = "Delete Student Class";
}

<h2 class="fw-bold text-danger mb-4">
    @ViewData["Title"]
</h2>

<div class="alert alert-warning">
    <strong>Warning!</strong>
    This action cannot be undone.
</div>

<div class="alert alert-danger shadow-sm">

    <h5>
        Are you sure you want to delete this Student Class?
    </h5>

</div>

<div class="card border-0 shadow-sm rounded-4">

    <div class="card-body">

        <dl class="row">

            <dt class="col-sm-3">@Html.DisplayNameFor(Model => Model.Level)</dt>
            <dd class="col-sm-9">@Model.Level</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(Model => Model.Series)</dt>
            <dd class="col-sm-9">@Model.Series</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(Model => Model.Shift)</dt>
            <dd class="col-sm-9">@Model.Shift</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(Model => Model.Capacity)</dt>
            <dd class="col-sm-9">@Model.Capacity</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(Model => Model.Code)</dt>
            <dd class="col-sm-9">@Model.Code</dd>

        </dl>

        <form asp-action="Delete">

            <input type="hidden"
                   asp-for="Id" />

            <div class="d-flex gap-2">

                <button type="submit"
                        class="btn btn-danger">

                    Delete

                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">

                    Cancel

                </a>

            </div>

        </form>

    </div>

</div>
