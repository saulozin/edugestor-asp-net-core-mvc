@using EduGestor.Models.Enums
@model EduGestor.Models.StudentClass

@{
    ViewData["Title"] = "Create Student Class";
}

<h2>@ViewData["Title"]</h2>

<hr />

<div class="row">

    <div class="col-md-6">

        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly"
                 class="text-danger">
            </div>

            <div class="form-group mb-3">
                <label asp-for="Level"
                       class="control-label">
                </label>

                <select asp-for="Level"
                        asp-items="Html.GetEnumSelectList<EducationLevel>()"
                        class="form-control">
                </select>

                <span asp-validation-for="Level"
                      class="text-danger">
                </span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Series"
                       class="control-label">
                </label>

                <select asp-for="Series"
                        asp-items="Html.GetEnumSelectList<Series>()"
                        class="form-control">
                </select>

                <span asp-validation-for="Series"
                      class="text-danger">
                </span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Shift"
                       class="control-label">
                </label>

                <select asp-for="Shift"
                        asp-items="Html.GetEnumSelectList<Shift>()"
                        class="form-control">
                </select>

                <span asp-validation-for="Shift"
                      class="text-danger">
                </span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Capacity"
                       class="control-label">
                </label>

                <input asp-for="Capacity"
                       class="form-control" />

                <span asp-validation-for="Capacity"
                      class="text-danger">
                </span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Code"
                       class="control-label">
                </label>

                <input asp-for="Code"
                       class="form-control" />

                <span asp-validation-for="Code"
                      class="text-danger">
                </span>
            </div>

            <div class="form-group">

                <input type="submit"
                       value="Create"
                       class="btn btn-primary" /> |

                <a asp-action="Index"
                   class="btn btn-secondary">
                    Cancel
                </a>

            </div>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
