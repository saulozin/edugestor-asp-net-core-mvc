@model EduGestor.Models.ViewModels.Portal.PortalViewModel
@using System.Globalization

@{
    ViewData["Title"] = "Guardian Portal";
}

<div class="mb-4">

    <h2 class="fw-bold">
        Welcome, @Model.GuardianName
    </h2>

    <p class="text-muted">
        Follow your children's academic progress
    </p>

</div>

@foreach (var student in Model.Students)
{
    <div class="card border-0 shadow-sm rounded-4 mb-5">

        <div class="card-body">

            <!-- HEADER -->
            <div class="d-flex justify-content-between align-items-center mb-4">

                <div>

                    <h4 class="fw-bold mb-1">
                        @student.StudentName
                    </h4>

                    <div class="text-muted">

                        Class:
                        <strong>
                            @student.ClassCode
                        </strong>

                    </div>

                </div>

            </div>

            <!-- CARDS -->
            <div class="row g-3 mb-4">

                <div class="col-md-3">

                    <div class="card bg-primary text-white border-0 rounded-4">

                        <div class="card-body">

                            <h6>
                                Subjects
                            </h6>

                            <h2 class="fw-bold">
                                @student.Grades.Count
                            </h2>

                        </div>

                    </div>

                </div>

                <div class="col-md-3">

                    <div class="card bg-success text-white border-0 rounded-4">

                        <div class="card-body">

                            <h6>
                                Average Grade
                            </h6>

                            <h2 class="fw-bold">

                                @(student.Grades.Any()
                                    ? student.Grades.Average(g => g.Grade).ToString("F1", CultureInfo.InvariantCulture)
                                    : "0")

                            </h2>

                        </div>

                    </div>

                </div>

                <div class="col-md-3">

                    <div class="card bg-info text-white border-0 rounded-4">

                        <div class="card-body">

                            <h6>
                                Average Frequency
                            </h6>

                            <h2 class="fw-bold">

                                @(student.Grades.Any()
                                    ? student.Grades.Average(g => g.Frequency).ToString("F0")
                                    : "0")%

                            </h2>

                        </div>

                    </div>

                </div>

                <div class="col-md-3">

                    @{
                        var approved =
                            student.Grades.All(g => g.Approved);
                    }

                    <div class="card border-0 rounded-4
                        @(approved
                            ? "bg-success text-white"
                            : "bg-danger text-white")">

                        <div class="card-body">

                            <h6>
                                Status
                            </h6>

                            <h4 class="fw-bold">

                                @(approved
                                    ? "Approved"
                                    : "Attention")

                            </h4>

                        </div>

                    </div>

                </div>

                <a asp-controller="Reports"
                   asp-action="ReportCard"
                   asp-route-registrationId="@student.RegistrationId"
                   class="btn btn-danger">

                    <i class="bi bi-file-earmark-pdf"></i>
                    Report Card

                </a>

            </div>

            <!-- TABLE -->
            <div class="table-responsive">

                <table class="table align-middle table-hover">

                    <thead class="table-light">

                        <tr>

                            <th>Discipline</th>
                            <th>Grade</th>
                            <th>Frequency</th>
                            <th>Bimester</th>
                            <th>Status</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var grade in student.Grades)
                        {
                            <tr>

                                <td>
                                    @grade.Discipline
                                </td>

                                <td>
                                    <strong>
                                        @grade.Grade.ToString("F1")
                                    </strong>
                                </td>

                                <td>
                                    @grade.Frequency.ToString("F0")%
                                </td>

                                <td>
                                    @grade.Bimester º
                                </td>

                                <td>

                                    @if (grade.Approved)
                                    {
                                        <span class="badge bg-success">
                                            Approved
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">
                                            Failed
                                        </span>
                                    }

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

            <!-- CHARTS -->
            <div class="row mt-5">

                <!-- GRADE EVOLUTION -->
                <div class="col-lg-6 mb-4">

                    <div class="card border-0 shadow-sm rounded-4">

                        <div class="card-body">

                            <h5 class="fw-bold mb-4">
                                Grade Evolution
                            </h5>

                            <canvas id="gradeChart-@student.StudentId"
                                    height="120">
                            </canvas>

                        </div>

                    </div>

                </div>

                <!-- FREQUENCY -->
                <div class="col-lg-6 mb-4">

                    <div class="card border-0 shadow-sm rounded-4">

                        <div class="card-body">

                            <h5 class="fw-bold mb-4">
                                Frequency
                            </h5>

                            <canvas id="frequencyChart-@student.StudentId"
                                    height="120">
                            </canvas>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>
}

@section Scripts
{
    <script>

        @foreach (var student in Model.Students)
        {
                // =========================
                // LABELS BIMESTERS
                // =========================

                var bimesterLabels =
                        student.Grades
                                .OrderBy(g => g.Bimester)
                                .Select(g => g.Bimester)
                                .Distinct()
                                .Select(b => $"'B{b}'");

                // =========================
                // GRADE CHART DATA
                // =========================

                var gradeLabels =
                        student.Grades
                                .OrderBy(g => g.Bimester)
                                .Select(g => $"'{g.Discipline} - B{g.Bimester}'");

                var grades =
                        student.Grades
                                .OrderBy(g => g.Bimester)
                                .Select(g =>
                                        g.Grade.ToString(
                                                System.Globalization.CultureInfo.InvariantCulture));

                // =========================
                // FREQUENCY DATASETS
                // =========================

                var disciplineGroups =
                        student.Grades
                                .GroupBy(g => g.Discipline);

                var frequencyDatasets = new List<string>();

                foreach (var group in disciplineGroups)
                {
                        var data = group
                                .OrderBy(g => g.Bimester)
                                .Select(g =>
                                        g.Frequency.ToString(
                                                System.Globalization.CultureInfo.InvariantCulture));

                        frequencyDatasets.Add($@"
                            {{
                                    label: '{group.Key}',
                                    data: [{string.Join(",", data)}]
                            }}");
                }

                <text>

                        // =========================
                        // GRADE CHART
                        // =========================

                        new Chart(
                            document.getElementById(
                                'gradeChart-@student.StudentId'),
                            {
                                type: 'line',

                                data:
                                {
                                    labels:
                                    [@Html.Raw(string.Join(",", gradeLabels))],

                                    datasets:
                                    [
                                        {
                                            label: 'Grades',

                                            data:
                                            [@string.Join(",", grades)],

                                            tension: 0.4,

                                            fill: true
                                        }
                                    ]
                                },

                                options:
                                {
                                    responsive: true,

                                    plugins:
                                    {
                                        legend:
                                        {
                                            display: true
                                        }
                                    },

                                    scales:
                                    {
                                        y:
                                        {
                                            type: 'linear',

                                            min: 0,

                                            max: 10,

                                            ticks:
                                            {
                                                stepSize: 2,

                                                autoSkip: false
                                            }
                                        }
                                    }
                                }
                            });

                        // =========================
                        // FREQUENCY CHART
                        // =========================

                        new Chart(
                            document.getElementById(
                                'frequencyChart-@student.StudentId'),
                            {
                                type: 'bar',

                                data:
                                {
                                    labels:
                                    [@Html.Raw(string.Join(",", bimesterLabels))],

                                    datasets:
                                    [
                                        @Html.Raw(string.Join(",", frequencyDatasets))
                                    ]
                                },

                                options:
                                {
                                    responsive: true,

                                    plugins:
                                    {
                                        legend:
                                        {
                                            display: true
                                        }
                                    },

                                    scales:
                                    {
                                        y:
                                        {
                                            beginAtZero: true,

                                            max: 100,

                                            ticks:
                                            {
                                                stepSize: 20
                                            }
                                        }
                                    }
                                }
                            });

                </text>
        }

    </script>
}
