@model EduGestor.Models.ViewModels.DisciplineClassSearchViewModel

@{
    ViewData["Title"] = "Academic Assignments";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>
        <h2 class="fw-bold mb-1">
            Academic Assignments
        </h2>

        <p class="text-muted mb-0">
            Manage class disciplines and teachers.
        </p>
    </div>

    <a asp-action="Create"
       class="btn btn-dark rounded-3">

        <i class="bi bi-plus-circle-fill"></i>
        New Assignment

    </a>

</div>

<!-- FILTERS -->
<div class="card border-0 shadow-sm rounded-4 mb-4">

    <div class="card-body">

        <form method="get"
              asp-action="Index">

            <div class="row g-3 align-items-end">

                <!-- GLOBAL SEARCH -->
                <div class="col-md-5">

                    <label class="form-label fw-semibold">
                        Search
                    </label>

                    <input asp-for="Search"
                           class="form-control"
                           placeholder="class, discipline or teacher..." />

                </div>

                <!-- BUTTON -->
                <div class="col-md-1 d-grid">

                    <button type="submit"
                            class="btn btn-dark">

                        <i class="bi bi-search"></i>

                    </button>

                </div>

            </div>

        </form>

    </div>

</div>

<!-- TABLE -->
<div class="card border-0 shadow-sm rounded-4">

    <div class="card-body">

        <table class="table align-middle table-hover">

            <thead>

                <tr>
                    <th>Class</th>
                    <th>Discipline</th>
                    <th>Teacher</th>
                    <th class="text-end">Actions</th>
                </tr>

            </thead>

            <tbody>

                @foreach (var obj in Model.DisciplineClasses)
                {
                    <tr>

                        <td>
                            <span class="badge bg-primary">
                                @obj.StudentClass?.Code
                            </span>
                        </td>

                        <td>
                            @obj.Discipline?.Name
                        </td>

                        <td>
                            @obj.Teacher?.Name
                        </td>

                        <td class="text-end">

                            <a asp-action="Details"
                               asp-route-id="@obj.Id"
                               class="btn btn-info btn-sm rounded-pill">

                                <i class="bi bi-eye-fill"></i>

                            </a>

                            <a asp-action="Edit"
                               asp-route-id="@obj.Id"
                               class="btn btn-warning btn-sm rounded-pill">

                                <i class="bi bi-pencil-fill"></i>

                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@obj.Id"
                               class="btn btn-danger btn-sm rounded-pill">

                                <i class="bi bi-trash-fill"></i>

                            </a>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

