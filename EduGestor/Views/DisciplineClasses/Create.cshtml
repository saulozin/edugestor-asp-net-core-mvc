@model EduGestor.Models.ViewModels.DisciplineClassFormViewModel

@{
    ViewData["Title"] = "Create Academic Assignment";
}

<div class="row justify-content-center">

    <div class="col-lg-6">

        <div class="card border-0 shadow-sm rounded-4">

            <div class="card-body p-4">

                <h3 class="fw-bold mb-4">
                    Form Data:
                </h3>

                <form asp-action="Create">

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3">
                    </div>

                    <div class="mb-3">

                        <label asp-for="DisciplineClass.StudentClassId"
                               class="form-label">
                            Class
                        </label>

                        <select asp-for="DisciplineClass.StudentClassId"
                                asp-items="Model.StudentClasses"
                                class="form-select rounded-3">

                            <option value="">
                                Select a class
                            </option>

                        </select>

                    </div>

                    <div class="mb-3">

                        <label asp-for="DisciplineClass.DisciplineId"
                               class="form-label">
                            Discipline
                        </label>

                        <select asp-for="DisciplineClass.DisciplineId"
                                asp-items="Model.Disciplines"
                                class="form-select rounded-3">

                            <option value="">
                                Select a discipline
                            </option>

                        </select>

                    </div>

                    <div class="mb-4">

                        <label asp-for="DisciplineClass.TeacherId"
                               class="form-label">
                            Teacher
                        </label>

                        <select asp-for="DisciplineClass.TeacherId"
                                asp-items="Model.Teachers"
                                class="form-select rounded-3">

                            <option value="">
                                Select a teacher
                            </option>

                        </select>

                    </div>

                    <div class="d-flex gap-2">

                        <button type="submit"
                                class="btn btn-primary rounded-3">

                            <i class="bi bi-check-circle-fill"></i>
                            Save

                        </button>

                        <a asp-action="Index"
                           class="btn btn-secondary rounded-3">

                            Back

                        </a>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

