@model EduGestor.Models.DisciplineClass

@{
    ViewData["Title"] = "Delete Assignment";
}

<div class="row justify-content-center">

    <div class="col-lg-6">

        <div class="card border-0 shadow-sm rounded-4">

            <div class="card-body p-4">

                <div class="text-center mb-4">

                    <i class="bi bi-exclamation-triangle-fill text-danger"
                       style="font-size: 60px;"></i>

                </div>

                <h3 class="fw-bold text-center mb-3">
                    Delete Assignment
                </h3>

                <p class="text-center text-muted mb-4">

                    Are you sure you want to delete this academic assignment?

                </p>

                <div class="bg-light rounded-4 p-3 mb-4">

                    <p class="mb-2">
                        <strong>Class:</strong>
                        @Model.StudentClass?.Code
                    </p>

                    <p class="mb-2">
                        <strong>Discipline:</strong>
                        @Model.Discipline?.Name
                    </p>

                    <p class="mb-0">
                        <strong>Teacher:</strong>
                        @Model.Teacher?.Name
                    </p>

                </div>

                <form asp-action="Delete">

                    <input type="hidden"
                           asp-for="Id" />

                    <div class="d-flex gap-2 justify-content-center">

                        <button type="submit"
                                class="btn btn-danger rounded-3">

                            <i class="bi bi-trash-fill"></i>
                            Delete

                        </button>

                        <a asp-action="Index"
                           class="btn btn-secondary rounded-3">

                            Cancel

                        </a>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>

