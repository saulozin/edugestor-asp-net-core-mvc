@model EduGestor.Models.ViewModels.Auth.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="card shadow border-0 rounded-4 auth-card">

    <div class="card-body p-5">

        <!-- HEADER -->
        <div class="text-center mb-4">

            <i class="bi bi-mortarboard-fill text-primary"
               style="font-size: 60px;">
            </i>

            <h2 class="fw-bold mt-3 mb-1">
                EduGestor
            </h2>

            <p class="text-muted mb-0">
                School Management System
            </p>

        </div>

        <!-- FORM -->
        <form asp-action="Login"
              method="post">

            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3">
            </div>

            <!-- EMAIL -->
            <div class="mb-3">

                <label asp-for="Email"
                       class="form-label fw-semibold">
                </label>

                <input asp-for="Email"
                       class="form-control form-control-lg rounded-3"
                       placeholder="Enter your email" />

                <span asp-validation-for="Email"
                      class="text-danger">
                </span>

            </div>

            <!-- PASSWORD -->
            <div class="mb-3">

                <label asp-for="Password"
                       class="form-label fw-semibold">
                </label>

                <input asp-for="Password"
                       type="password"
                       class="form-control form-control-lg rounded-3"
                       placeholder="Enter your password" />

                <span asp-validation-for="Password"
                      class="text-danger">
                </span>

            </div>

            <!-- REMEMBER -->
            <div class="form-check mb-4">

                <input asp-for="RememberMe"
                       class="form-check-input" />

                <label asp-for="RememberMe"
                       class="form-check-label">
                </label>

            </div>

            <!-- BUTTON -->
            <button type="submit"
                    class="btn btn-primary btn-lg w-100 rounded-3 shadow-sm">

                <i class="bi bi-box-arrow-in-right"></i>
                Login

            </button>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
