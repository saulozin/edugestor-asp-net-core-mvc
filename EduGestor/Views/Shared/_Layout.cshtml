@using Microsoft.AspNetCore.Identity
@using EduGestor.Models.Identity

@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager

<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>
        @ViewData["Title"] - EduGestor
    </title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
          rel="stylesheet" />

    <style>

            body {
                overflow-x: hidden;
                background: #f3f4f6;
            }

            /* SIDEBAR */
            .sidebar {
                width: 250px;
                height: 100vh;
                position: fixed;
                top: 0;
                left: 0;
                background: #1f2937;
                color: white;
                padding-top: 20px;
            }

                .sidebar .brand {
                    font-size: 20px;
                    font-weight: bold;
                    padding: 0 20px 20px 20px;
                }

                .sidebar a {
                    color: #cbd5e1;
                    text-decoration: none;
                    display: block;
                    padding: 12px 20px;
                    border-radius: 8px;
                    margin: 4px 10px;
                    transition: .2s;
                }

                    .sidebar a:hover {
                        background: #374151;
                        color: white;
                    }

                    .sidebar a.active {
                        background: #2563eb;
                        color: white;
                    }

            /* CONTENT */
            .content {
                margin-left: 250px;
                padding: 20px;
                min-height: 100vh;
            }

            /* TOPBAR */
            .topbar {
                height: 70px;
                background: white;
                border-bottom: 1px solid #e5e7eb;
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 0 20px;
                margin-bottom: 20px;
            }

            /* LOGIN PAGES */
            .auth-container {
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 30px;
            }

    </style>

</head>

<body>

    @if (SignInManager.IsSignedIn(User))
    {
        <!-- SIDEBAR -->
        <div class="sidebar">

            <!-- BRAND -->
            <div class="brand">

                <i class="bi bi-mortarboard-fill"></i>
                EduGestor

            </div>

            <!-- DASHBOARD -->
            @if (!User.IsInRole("Guardian"))
            {
                <a asp-controller="Home"
                   asp-action="Index">

                    <i class="bi bi-speedometer2"></i>
                    Dashboard

                </a>
            }

            <!-- ADMIN + SECRETARY -->
            @if (User.IsInRole("Admin") ||
                 User.IsInRole("Secretary"))
            {
                <a asp-controller="Registrations"
                   asp-action="Index">

                    <i class="bi bi-journal-text"></i>
                    Registrations

                </a>

                <a asp-controller="Students"
                   asp-action="Index">

                    <i class="bi bi-person"></i>
                    Students

                </a>

                <a asp-controller="Guardians"
                   asp-action="Index">

                    <i class="bi bi-people"></i>
                    Guardians

                </a>

                <a asp-controller="StudentClasses"
                   asp-action="Index">

                    <i class="bi bi-easel2"></i>
                    Classes

                </a>

                <a asp-controller="Disciplines"
                   asp-action="Index">

                    <i class="bi bi-journal-bookmark"></i>
                    Disciplines

                </a>

                <a asp-controller="DisciplineClasses"
                   asp-action="Index">

                    <i class="bi bi-diagram-3-fill"></i>
                    Academic Assignments

                </a>
            }

            <!-- ADMIN -->
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Teachers"
                   asp-action="Index">

                    <i class="bi bi-person-badge"></i>
                    Teachers

                </a>
            }

            <!-- ADMIN + TEACHER -->
            @if (User.IsInRole("Admin") ||
                 User.IsInRole("Teacher"))
            {
                <a asp-controller="Grades"
                   asp-action="Index">

                    <i class="bi bi-bar-chart"></i>
                    Grades

                </a>
            }

            <!-- USERS -->
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Account"
                   asp-action="Register">

                    <i class="bi bi-person-plus"></i>
                    Users

                </a>
            }

            <!-- GUARDIAN -->
            @if (User.IsInRole("Guardian"))
            {
                <a asp-controller="Portal"
                   asp-action="Index">

                    <i class="bi bi-journal-check"></i>
                    My Children

                </a>
            }

        </div>

        <!-- CONTENT -->
        <div class="content">

            <!-- TOPBAR -->
            <div class="topbar shadow-sm rounded">

                <!-- PAGE TITLE -->
                <div>

                    <h5 class="mb-0">
                        @ViewData["Title"]
                    </h5>

                </div>

                <!-- USER INFO -->
                <div class="d-flex align-items-center gap-3">

                    <div class="text-end">

                        <div class="fw-semibold">

                            @User.Identity?.Name

                        </div>

                        <small class="text-muted">

                            @if (User.IsInRole("Admin"))
                            {
                                <span>Administrator</span>
                            }
                            else if (User.IsInRole("Secretary"))
                            {
                                <span>Secretary</span>
                            }
                            else if (User.IsInRole("Teacher"))
                            {
                                <span>Teacher</span>
                            }
                            else if (User.IsInRole("Guardian"))
                            {
                                <span>Guardian</span>
                            }

                        </small>

                    </div>

                    <!-- LOGOUT -->
                    <form asp-controller="Account"
                          asp-action="Logout"
                          method="post">

                        <button type="submit"
                                class="btn btn-sm btn-outline-danger">

                            <i class="bi bi-box-arrow-right"></i>
                            Logout

                        </button>

                    </form>

                </div>

            </div>

            <!-- PAGE CONTENT -->
            <main role="main">

                @RenderBody()

            </main>

        </div>
    }
    else
    {
        <!-- LOGIN / REGISTER -->
        <main class="auth-container">

            @RenderBody()

        </main>
    }

    <!-- SCRIPTS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">
    </script>

    @RenderSection("Scripts", required: false)

</body>

</html>
